generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String
  password           String
  role               String              @default("STUDENT")
  createdAt          DateTime            @default(now())
  emailVerified      Boolean             @default(true)
  resetToken         String?             @unique
  resetTokenExpiry   DateTime?
  verificationToken  String?             @unique
  googleId           String?             @unique
  enrollments        Enrollment[]
  posts              Post[]
  replies            Reply[]
  submissions        Submission[]
  videoProgresses    VideoProgress[]
  deadlineExceptions DeadlineException[]
}

model Course {
  id            String       @id @default(cuid())
  title         String
  description   String?
  thumbnail     String?
  status        String       @default("published")
  password      String       @default("doacademy")
  createdAt     DateTime     @default(now())
  weightForum   Int          @default(10)
  weightLab     Int          @default(30)
  weightProject Int          @default(40)
  weightQuiz    Int          @default(20)
  enrollments   Enrollment[]
  weeks         Week[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  status    String   @default("ACTIVE")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Week {
  id        String @id @default(cuid())
  title     String
  order     Int
  isVisible Boolean @default(true)
  courseId  String
  days      Day[]
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Day {
  id                  String              @id @default(cuid())
  title               String
  order               Int
  isVisible           Boolean             @default(true)
  videoId             String?
  materialUrl         String?
  weekId              String
  assignmentUrl       String?
  isDeliveryDay       Boolean             @default(false)
  gradingSeverity     Int                 @default(1)
  assignmentType      String              @default("LAB")
  dueDate             DateTime?
  forumTopics         String?
  codeTemplate        String?
  enablePlagiarism    Boolean             @default(false)
  expectedOutput      String?
  isCodingExercise    Boolean             @default(false)
  similarityThreshold Float               @default(0.9)
  exerciseDescription String?
  testCases           Json?
  summaryUrl          String?
  week                Week                @relation(fields: [weekId], references: [id], onDelete: Cascade)
  posts               Post[]
  resources           Resource[]
  submissions         Submission[]
  videoProgresses     VideoProgress[]
  deadlineExceptions  DeadlineException[]
}

model Resource {
  id    String @id @default(cuid())
  title String
  url   String
  type  String
  dayId String
  day   Day    @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  dayId     String
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VideoProgress {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  seconds   Int      @default(0)
  percent   Int?
  updatedAt DateTime @updatedAt
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

model SiteConfig {
  key   String @id
  value Json
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  content   String
  fileName  String
  status    String   @default("PENDING")
  grade     Float?
  feedback  Json?
  createdAt DateTime @default(now())
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
  @@index([userId])
  @@index([dayId])
}

model Communication {
  id              String   @id @default(cuid())
  subject         String
  content         String
  recipientCount  Int
  targetGroupId   String?
  targetGroupName String
  createdAt       DateTime @default(now())
}

model AttendanceSession {
  id        String   @id @default(cuid())
  code      String
  expiresAt DateTime
  sheetName String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DeadlineException {
  id         String   @id @default(cuid())
  userId     String
  dayId      String
  newDueDate DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  day  Day  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
  @@index([userId])
  @@index([dayId])
}
