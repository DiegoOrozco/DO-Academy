generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  password         String       // Hashed
  role             String       @default("STUDENT") // STUDENT or ADMIN
  emailVerified    Boolean      @default(true)
  verificationToken String?      @unique
  resetToken       String?      @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime     @default(now())
  enrollments      Enrollment[]
  posts            Post[]
  replies          Reply[]
  videoProgresses  VideoProgress[]
  submissions      Submission[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  status      String       @default("published")
  password    String       @default("doacademy")
  createdAt     DateTime     @default(now())
  weightQuiz    Int          @default(20)
  weightLab     Int          @default(30)
  weightForum   Int          @default(10)
  weightProject Int          @default(40)
  enrollments   Enrollment[]
  weeks         Week[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Week {
  id        String   @id @default(cuid())
  title     String
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  days      Day[]
}

model Day {
  id        String     @id @default(cuid())
  title     String
  order     Int
  videoId       String?    // YouTube video ID
  materialUrl   String?
  isDeliveryDay Boolean   @default(false)
  assignmentType String   @default("LAB") // QUIZ, LAB, FORUM, PROJECT
  dueDate       DateTime? // For deadlines
  assignmentUrl String?
  gradingSeverity Int     @default(1) // 1 to 5
  weekId        String
  week          Week      @relation(fields: [weekId], references: [id], onDelete: Cascade)
  resources Resource[]
  posts     Post[]
  videoProgresses VideoProgress[]
  submissions     Submission[]
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String   // e.g., "DRIVE", "GITHUB", "PDF"
  dayId     String
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  dayId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  replies   Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model VideoProgress {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  seconds   Int      @default(0)
  percent   Int?
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

model SiteConfig {
  key   String @id
  value Json
}

model Submission {
  id           String   @id @default(cuid())
  userId       String
  dayId        String
  content      String   @db.Text
  fileName     String
  status       String   @default("PENDING") // PENDING, GRADED, FAILED
  grade        Float?
  feedback     Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  day  Day  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dayId])
}
