generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  password    String       // In a real app, hashed
  role        String       @default("STUDENT") // STUDENT or ADMIN
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  posts       Post[]
  replies     Reply[]
  videoProgresses VideoProgress[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  status      String       @default("published")
  password    String       @default("doacademy")
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  weeks       Week[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Week {
  id        String   @id @default(cuid())
  title     String
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  days      Day[]
}

model Day {
  id        String     @id @default(cuid())
  title     String
  order     Int
  videoId   String?    // YouTube video ID
  materialUrl String?
  weekId    String
  week      Week       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  resources Resource[]
  posts     Post[]
  videoProgresses VideoProgress[]
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String   // e.g., "DRIVE", "GITHUB", "PDF"
  dayId     String
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  dayId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  replies   Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model VideoProgress {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  seconds   Int      @default(0)
  percent   Int?
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

model SiteConfig {
  key   String @id
  value Json
}
