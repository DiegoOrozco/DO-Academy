{
  "name": "course-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma db push && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "cleanup:fakes": "tsx scripts/cleanup-fake-users.ts",
    "cleanup:fakes:dry": "tsx scripts/cleanup-fake-users.ts --dry-run",
    "cleanup:fakes:by-password": "tsx scripts/cleanup-fake-users.ts --by-password",
    "purge:users:dry": "tsx scripts/purge-users.ts --dry-run --keep-role=ADMIN",
    "purge:users": "tsx scripts/purge-users.ts --yes",
    "purge:users:keep-prof": "tsx scripts/purge-users.ts --keep-role=ADMIN --yes"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/pg": "^8.18.0",
    "@vercel/blob": "^2.3.0",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
